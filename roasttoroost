  <style>
    /* ── Base & Animations ──────────────────────────────────── */
    * { box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Source Sans 3', system-ui, sans-serif;
    }

    /* Page load fade-in */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up {
      animation: fadeUp 0.6s ease-out both;
    }
    .fade-up-1 { animation-delay: 0.08s; }
    .fade-up-2 { animation-delay: 0.16s; }
    .fade-up-3 { animation-delay: 0.24s; }
    .fade-up-4 { animation-delay: 0.32s; }
    .fade-up-5 { animation-delay: 0.40s; }
    .fade-up-6 { animation-delay: 0.48s; }

    /* Card hover lift */
    .card-hover {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(74, 47, 31, 0.15);
    }

    /* Steam animation for header */
    @keyframes steam {
      0%   { opacity: 0; transform: translateY(0) scaleX(1); }
      50%  { opacity: 0.6; }
      100% { opacity: 0; transform: translateY(-28px) scaleX(1.4); }
    }
    .steam-line {
      position: absolute;
      width: 3px;
      height: 16px;
      background: rgba(212, 160, 23, 0.4);
      border-radius: 50%;
      animation: steam 2s ease-in-out infinite;
    }

    /* Grain overlay for warmth */
    .grain::before {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      pointer-events: none;
      opacity: 0.025;
      z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    /* Dark mode overrides */
    .dark .grain::before { opacity: 0.04; }

    /* Weather icon bounce */
    @keyframes gentleBounce {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-3px); }
    }
    .weather-icon {
      animation: gentleBounce 3s ease-in-out infinite;
    }

    /* Badge shimmer */
    .badge-shimmer {
      position: relative;
      overflow: hidden;
    }
    .badge-shimmer::after {
      content: '';
      position: absolute;
      top: 0; left: -100%; width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      animation: shimmer 3s ease-in-out infinite;
    }
    @keyframes shimmer {
      0%   { left: -100%; }
      100% { left: 200%; }
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #F5EDE0; }
    ::-webkit-scrollbar-thumb { background: #C4A882; border-radius: 4px; }
    .dark ::-webkit-scrollbar-track { background: #1a1a1a; }
    .dark ::-webkit-scrollbar-thumb { background: #4A2F1F; }

    /* Print styles */
    @media print {
      .no-print { display: none !important; }
      body { background: white !important; }
      .dark body { color: #1a1a1a !important; }
    }
  </style>

