  <!-- ═══════════════════════════════════════════════════════════ -->

  <script>
  (function() {
    'use strict';

    // ── Live Date ────────────────────────────────────────────
    const dateEl = document.getElementById('liveDate');
    const now = new Date();
    dateEl.textContent = now.toLocaleDateString('en-US', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });

    // ── Dark Mode Toggle ────────────────────────────────────
    const toggle = document.getElementById('themeToggle');
    const html = document.documentElement;

    // Check saved preference or default to light
    if (localStorage.getItem('r2r-theme') === 'dark') {
      html.classList.add('dark');
    }

    toggle.addEventListener('click', () => {
      html.classList.toggle('dark');
      localStorage.setItem('r2r-theme', html.classList.contains('dark') ? 'dark' : 'light');
    });

    // ── Render Events ───────────────────────────────────────
    const eventsGrid = document.getElementById('eventsGrid');
    EVENTS.forEach(ev => {
      eventsGrid.innerHTML += `
        <a href="${ev.link}" target="_blank" rel="noopener"
          class="card-hover bg-white/70 dark:bg-bean/30 rounded-2xl p-5 border border-bean/5 dark:border-cream/5 block group">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-3xl">${ev.icon}</span>
            <div>
              <h3 class="font-display text-lg font-bold text-bean dark:text-cream group-hover:text-honey transition-colors leading-tight">${ev.title}</h3>
              <p class="text-xs text-honey font-semibold uppercase tracking-wider mt-0.5">${ev.date}</p>
            </div>
          </div>
          <p class="text-sm text-bean/60 dark:text-cream/60 font-body leading-relaxed">${ev.desc}</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs font-semibold text-honey/70 group-hover:text-honey transition-colors">
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i> Details
          </span>
        </a>
      `;
    });

    // ── Render Deals ────────────────────────────────────────
    const dealsGrid = document.getElementById('dealsGrid');
    DEALS.forEach(deal => {
      dealsGrid.innerHTML += `
        <a href="${deal.link}" target="_blank" rel="noopener"
          class="card-hover bg-white/70 dark:bg-bean/30 rounded-2xl p-5 border border-bean/5 dark:border-cream/5 block group relative overflow-hidden">
          <div class="absolute top-3 right-3 badge-shimmer bg-honey/15 dark:bg-honey/20 text-honey text-xs font-bold px-2.5 py-1 rounded-full">
            ${deal.badge}
          </div>
          <h3 class="font-display text-lg font-bold text-bean dark:text-cream group-hover:text-honey transition-colors pr-20">${deal.supplier}</h3>
          <p class="text-xs text-cinnamon dark:text-latte font-semibold mb-2">${deal.location}</p>
          <p class="text-sm text-bean/60 dark:text-cream/60 font-body leading-relaxed">${deal.promo}</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs font-semibold text-honey/70 group-hover:text-honey transition-colors">
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i> Visit Supplier
          </span>
        </a>
      `;
    });

    // ── Weather Fetch (Open-Meteo) ──────────────────────────
    const weatherUrl = 'https://api.open-meteo.com/v1/forecast?latitude=33.18&longitude=-97.29&daily=temperature_2m_max,temperature_2m_min,weathercode&temperature_unit=fahrenheit&timezone=America%2FChicago&forecast_days=5';

    const WMO_ICONS = {
      0: { icon: '☀️',  label: 'Clear' },
      1: { icon: '🌤️', label: 'Mostly Clear' },
      2: { icon: '⛅',  label: 'Partly Cloudy' },
      3: { icon: '☁️',  label: 'Overcast' },
      45:{ icon: '🌫️', label: 'Foggy' },
      48:{ icon: '🌫️', label: 'Freezing Fog' },
      51:{ icon: '🌦️', label: 'Light Drizzle' },
      53:{ icon: '🌦️', label: 'Drizzle' },
      55:{ icon: '🌧️', label: 'Heavy Drizzle' },
      61:{ icon: '🌧️', label: 'Light Rain' },
      63:{ icon: '🌧️', label: 'Rain' },
      65:{ icon: '🌧️', label: 'Heavy Rain' },
      71:{ icon: '🌨️', label: 'Light Snow' },
      73:{ icon: '🌨️', label: 'Snow' },
      75:{ icon: '❄️',  label: 'Heavy Snow' },
      80:{ icon: '🌦️', label: 'Showers' },
      81:{ icon: '🌧️', label: 'Heavy Showers' },
      82:{ icon: '⛈️',  label: 'Violent Showers' },
      95:{ icon: '⛈️',  label: 'Thunderstorm' },
      96:{ icon: '⛈️',  label: 'T-storm w/ Hail' },
      99:{ icon: '⛈️',  label: 'T-storm w/ Heavy Hail' },
    };

    async function fetchWeather() {
      const container = document.getElementById('weatherContainer');
      try {
        const res = await fetch(weatherUrl);
        const data = await res.json();
        const { time, temperature_2m_max: highs, temperature_2m_min: lows, weathercode: codes } = data.daily;

        container.innerHTML = '';
        const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

        time.forEach((dateStr, i) => {
          const d = new Date(dateStr + 'T12:00:00');
          const dayName = i === 0 ? 'Today' : dayNames[d.getDay()];
          const wmo = WMO_ICONS[codes[i]] || { icon: '🌡️', label: 'N/A' };

          container.innerHTML += `
            <div class="card-hover bg-white/70 dark:bg-bean/30 rounded-2xl p-4 border border-bean/5 dark:border-cream/5 text-center">
              <p class="text-xs font-bold uppercase tracking-widest text-bean/50 dark:text-cream/40 mb-1">${dayName}</p>
              <p class="text-xs text-bean/40 dark:text-cream/30 mb-2">${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</p>
              <div class="weather-icon text-4xl mb-2" style="animation-delay:${i * 0.3}s">${wmo.icon}</div>
              <p class="text-xs text-bean/50 dark:text-cream/50 mb-2 font-medium">${wmo.label}</p>
              <p class="font-display text-xl font-bold text-bean dark:text-cream">${Math.round(highs[i])}°</p>
              <p class="text-sm text-bean/40 dark:text-cream/40">${Math.round(lows[i])}°</p>
            </div>
          `;
        });

        // ── Temperature Chart ─────────────────────────────
        const ctx = document.getElementById('tempChart').getContext('2d');
        const labels = time.map((t, i) => {
          const d = new Date(t + 'T12:00:00');
          return i === 0 ? 'Today' : d.toLocaleDateString('en-US', { weekday: 'short' });
        });

        new Chart(ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [
              {
                label: 'High °F',
                data: highs.map(Math.round),
                borderColor: '#D4A017',
                backgroundColor: 'rgba(212,160,23,0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 5,
                pointBackgroundColor: '#D4A017',
              },
              {
                label: 'Low °F',
                data: lows.map(Math.round),
                borderColor: '#C4A882',
                backgroundColor: 'rgba(196,168,130,0.08)',
                fill: true,
                tension: 0.4,
                pointRadius: 5,
                pointBackgroundColor: '#C4A882',
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                labels: {
                  color: html.classList.contains('dark') ? '#F5EDE0' : '#4A2F1F',
                  font: { family: '"Source Sans 3"', size: 12 },
                },
              },
            },
            scales: {
              y: {
                ticks: { color: html.classList.contains('dark') ? '#F5EDE088' : '#4A2F1F88', font: { family: '"Source Sans 3"' } },
                grid:  { color: html.classList.contains('dark') ? '#F5EDE010' : '#4A2F1F08' },
              },
              x: {
                ticks: { color: html.classList.contains('dark') ? '#F5EDE088' : '#4A2F1F88', font: { family: '"Source Sans 3"' } },
                grid:  { display: false },
              },
            },
          },
        });

      } catch (err) {
        container.innerHTML = `
          <div class="col-span-full text-center py-8 text-bean/40 dark:text-cream/30">
            <i class="fa-solid fa-triangle-exclamation text-2xl mb-2 block text-cinnamon"></i>
            Weather unavailable — please refresh to try again.
          </div>
        `;
        console.error('Weather fetch error:', err);
      }
    }

    fetchWeather();

    // ── Seasonal Drink Inspiration ──────────────────────────
    const month = now.getMonth(); // 0-indexed
    let season, drinks;

    if (month >= 2 && month <= 4) {
      season = 'spring';
      drinks = [
        { name: 'Lavender Honey Latte',        emoji: '💜', desc: 'Espresso with local honey, steamed milk & a touch of lavender syrup. Light and floral.', tip: 'Top with dried lavender buds for a pretty presentation.' },
        { name: 'Texas Pecan Cold Brew',        emoji: '🥜', desc: 'Slow-steeped cold brew with house-made pecan syrup & a splash of oat milk.', tip: 'Use locally sourced pecans for that real Texas flavor.' },
        { name: 'Strawberry Matcha Lemonade',   emoji: '🍓', desc: 'Iced matcha layered over fresh strawberry purée and sparkling lemonade.', tip: 'Beautiful Instagram-worthy layers — let customers pour themselves!' },
        { name: 'Cinnamon Roll Latte',          emoji: '🍥', desc: "Inspired by your famous scratch-made cinnamon rolls — cinnamon, brown sugar, cream cheese foam.", tip: "Pair it with an actual cinnamon roll for the ultimate combo deal." },
        { name: 'Honey Bee Flat White',         emoji: '🐝', desc: 'Velvety flat white sweetened with raw local honey and a light dusting of cinnamon.', tip: 'Source honey from Denton County beekeepers for a hyper-local story.' },
        { name: 'Mint Mocha Iced',              emoji: '🌿', desc: 'Rich chocolate mocha poured over ice with fresh mint and whipped cream.', tip: 'Muddle real mint leaves for a garden-fresh twist.' },
      ];
    } else if (month >= 5 && month <= 7) {
      season = 'summer';
      drinks = [
        { name: 'Watermelon Agua Fresca Coffee', emoji: '🍉', desc: 'Cold brew meets fresh watermelon agua fresca — surprisingly refreshing.', tip: 'Perfect for Ponder's 100°+ days. Serve in Mason jars.' },
        { name: 'Coconut Vanilla Cold Brew',     emoji: '🥥', desc: 'Smooth cold brew, coconut cream & Madagascar vanilla over crushed ice.', tip: 'Freeze coconut milk into cubes so it never gets watered down.' },
        { name: 'Peach Sweet Tea Espresso',      emoji: '🍑', desc: 'A true Texas fusion — sweet peach tea with a shot of espresso over ice.', tip: 'Use Hill Country peaches when they\'re in season.' },
        { name: 'Mexican Horchata Latte',        emoji: '🥛', desc: 'Creamy cinnamon-rice milk horchata mixed with espresso. Sweet and spiced.', tip: 'Batch the horchata base daily for consistent creaminess.' },
        { name: 'Frozen Caramel Macchiato',      emoji: '🧊', desc: 'Blended espresso with caramel, vanilla & milk — frozen to perfection.', tip: 'Drizzle caramel inside the cup for a beautiful spiral effect.' },
        { name: 'Blueberry Lemon Cold Brew',     emoji: '🫐', desc: 'Bright blueberry compote and lemon zest stirred into nitrogen cold brew.', tip: 'Garnish with a lemon wheel and a few fresh berries.' },
      ];
    } else if (month >= 8 && month <= 10) {
      season = 'fall';
      drinks = [
        { name: 'Pumpkin Spice Latte (Texas Style)', emoji: '🎃', desc: 'Real pumpkin purée, warm spices, espresso & steamed milk. No artificial stuff.', tip: 'Add a pinch of cayenne for a subtle Texas kick.' },
        { name: 'Maple Pecan Cappuccino',             emoji: '🍁', desc: 'Rich cappuccino topped with maple syrup foam and candied pecan pieces.', tip: 'Candy the pecans in-house — they smell amazing and draw people in.' },
        { name: 'Apple Cider Chai',                   emoji: '🍎', desc: 'Hot apple cider blended with spiced chai concentrate. Autumn in a cup.', tip: 'Rim the mug with cinnamon sugar for that extra fall feeling.' },
        { name: 'Salted Caramel Mocha',               emoji: '🧂', desc: 'Dark chocolate mocha with house salted caramel and a flaky salt finish.', tip: 'Use Maldon sea salt flakes — the crunch makes it special.' },
        { name: 'Brown Sugar Oat Latte',              emoji: '🤎', desc: 'Espresso with oat milk and torched brown sugar syrup. Cozy and sweet.', tip: 'Brûlée the brown sugar on top with a kitchen torch for drama.' },
        { name: 'Sweet Potato Pie Latte',             emoji: '🍠', desc: 'Roasted sweet potato purée, warm spices, espresso & marshmallow cream.', tip: 'A Southern classic turned coffee drink — pairs with your cinnamon rolls!' },
      ];
    } else {
      season = 'winter';
      drinks = [
        { name: 'Gingerbread Latte',             emoji: '🏠', desc: 'Warm ginger, molasses & cinnamon espresso with whipped cream & cookie crumbs.', tip: 'Serve with a mini gingerbread man perched on the rim.' },
        { name: 'Peppermint White Mocha',        emoji: '🍫', desc: 'White chocolate mocha with real peppermint and crushed candy cane topping.', tip: 'Use white chocolate shavings on top for an elegant touch.' },
        { name: 'Mexican Hot Chocolate',         emoji: '🌶️', desc: 'Rich dark chocolate, cinnamon, a hint of chili & topped with whipped cream.', tip: 'Use Ibarra chocolate for authenticity — customers will notice.' },
        { name: 'Eggnog Espresso',               emoji: '🥚', desc: 'Creamy eggnog steamed with espresso and a dusting of fresh nutmeg.', tip: 'Offer a dairy-free version with oat-based nog.' },
        { name: 'Cranberry Orange Americano',    emoji: '🍊', desc: 'Bright cranberry syrup and orange zest over a classic hot Americano.', tip: 'Garnish with a dehydrated orange wheel — gorgeous and shelf-stable.' },
        { name: 'Fireside S\'mores Mocha',       emoji: '🔥', desc: 'Chocolate mocha with graham cracker crumbs and toasted marshmallow cream.', tip: 'Toast the marshmallow with a torch tableside for a fun experience.' },
      ];
    }

    const drinksGrid = document.getElementById('drinksGrid');
    drinks.forEach(drink => {
      drinksGrid.innerHTML += `
        <div class="card-hover bg-white/70 dark:bg-bean/30 rounded-2xl p-5 border border-bean/5 dark:border-cream/5">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-3xl">${drink.emoji}</span>
            <h3 class="font-display text-lg font-bold text-bean dark:text-cream leading-tight">${drink.name}</h3>
          </div>
          <p class="text-sm text-bean/60 dark:text-cream/60 font-body leading-relaxed mb-3">${drink.desc}</p>
          <div class="flex items-start gap-2 bg-honey/10 dark:bg-honey/5 rounded-xl px-3 py-2">
            <span class="text-xs mt-0.5">💡</span>
            <p class="text-xs text-bean/50 dark:text-cream/40 font-body italic">${drink.tip}</p>
          </div>
        </div>
      `;
    });

  })();
  </script>

